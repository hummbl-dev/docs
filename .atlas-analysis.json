    "KillSwitch.disengage(reason, triggered_by)",
    "KillSwitch.engaged() -> bool",
    "DelegationTokenManager.create_token(agent_id, scope, ttl, chain_depth)",
    "DelegationTokenManager.validate_token(token)",
    "DelegationTokenManager.check_least_privilege(token, op)",
    "CircuitBreaker.call(fn, *args)",
    "CircuitBreaker.state -> CircuitBreakerState",
    "CapabilityFence.check(capability) -> bool",
    "CapabilityFence.guard(capability) — context manager",
    "CapabilityFence.from_delegation_token(token, denied)",
    "Engine.select(code) -> Model",
