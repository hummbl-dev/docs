  "keyFeatures": [
    "Append-only JSONL governance bus for assessor-readable audit trails",
    "Four-mode kill switch that persists across process restarts",
    "HMAC-SHA256 signed delegation tokens with scope and chain-depth enforcement",
    "Circuit breaker state machine wrapping every external adapter",
    "CapabilityFence for scope-narrowing in multi-agent delegation chains",
    "MCP Attestation for local-first governance of MCP-native agents",
    "120 canonical mental models (Base120) across 6 transformation families",
    "Arbiter agent-aware code quality scoring CLI with per-commit attribution",
    "stdlib-only — zero third-party runtime dependencies, air-gap capable",
    "Readiness assessments for EU AI Act, NIST AI RMF, ISO 42001, Colorado AI Act, Singapore IMDA"
  ],
  "publicApiSurface": [
    "pip install hummbl-governance",
    "pip install hummbl-base120",
    "npm install @hummbl/mcp-server",
    "pip install arbiter-score",
